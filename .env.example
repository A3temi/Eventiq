# ============================================
# Eventiq — Environment Variables
# Copy to .env.local and fill in real values
# ============================================

# --- Stripe (Sandbox) ---
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Exa API ---
EXA_API_KEY=xxx

# --- AWS (also powers AI via Bedrock — no separate LLM API keys needed) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_ACCOUNT_ID=000000000000
DYNAMODB_TABLE_PREFIX=eventbot
S3_ASSETS_BUCKET=eventbot-assets-YOUR_ACCOUNT_ID
SQS_AGENT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/eventbot-agent-tasks

# --- Email (Gmail SMTP — no domain needed) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM=your-email@gmail.com

# --- WAHA (WhatsApp on ECS) ---
WAHA_API_URL=http://YOUR_ECS_PUBLIC_IP:3000
WAHA_API_KEY=your-api-key
WAHA_SESSION_NAME=default

# --- App ---
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://your-app.vercel.app

# --- Credits ---
CREDITS_PER_EXA_SEARCH=2
CREDITS_PER_STAGEHAND_SESSION=5
CREDITS_PER_EMAIL=1
CREDITS_PER_WHATSAPP=1
CREDITS_PER_LLM_CALL=1
